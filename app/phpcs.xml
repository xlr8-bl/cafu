<?xml version="1.0"?>
<ruleset name="SRWA">
    <description>PSR-12 with light project rules. Paths are relative to this file (app/).</description>
    <file>src</file>
    <file>public</file>
    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>tests/*</exclude-pattern>
    <!-- Built React bundle — minified JS/CSS, not source. -->
    <exclude-pattern>public/dist/*</exclude-pattern>
    <!-- Admin + legal pages mix HTML + PHP heavily; PSR-12 inline-HTML rules don't fit. -->
    <exclude-pattern>public/admin/*.php</exclude-pattern>
    <exclude-pattern>public/legal/*.php</exclude-pattern>
    <!-- Entry-point scripts (router, index) intentionally mix function definitions with the dispatch
         that uses them. Splitting them into separate files for one PSR-12 rule isn't worth it. -->
    <exclude-pattern>public/api/router.php</exclude-pattern>
    <rule ref="PSR12"/>
    <arg name="colors"/>
    <arg value="p"/>
</ruleset>
