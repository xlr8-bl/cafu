{
    "name": "srwa/smart-restaurant-web-app",
    "description": "Smart Restaurant Web App — CEC418 course project.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "ext-json": "*",
        "monolog/monolog": "^3.5",
        "robmorgan/phinx": "^0.16",
        "sentry/sentry": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": { "Srwa\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Srwa\\Tests\\": "tests/" }
    },
    "scripts": {
        "test":         "phpunit --configuration phpunit.xml --testdox",
        "lint":         "phpcs --standard=phpcs.xml",
        "fix":          "phpcbf --standard=phpcs.xml",
        "migrate":      "phinx migrate -c ../db/phinx.php",
        "rollback":     "phinx rollback -c ../db/phinx.php",
        "migrate-info": "phinx status -c ../db/phinx.php"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform-check": false
    }
}
