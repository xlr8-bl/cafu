APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8090

DB_HOST=mysql
DB_PORT=3306
DB_NAME=srwa
DB_USER=srwa
DB_PASS=srwa_dev_password

MYSQL_ROOT_PASSWORD=root_dev_password

# Observability ---------------------------------------------------------------
# LOG_LEVEL controls Monolog's threshold. One of: debug, info, notice, warning, error.
LOG_LEVEL=info
# Leave SENTRY_DSN empty to disable Sentry. Format: https://<key>@<org>.ingest.sentry.io/<project>.
SENTRY_DSN=
APP_RELEASE=dev

# HTTPS / reverse proxy -------------------------------------------------------
# Leave SITE_ADDRESS unset in dev — Caddy serves plain HTTP on :8090.
# In production set to your real domain (e.g. cafu.example.com) AND map the
# Caddy container's host ports to 80:80 + 443:443. Caddy then auto-fetches a
# Let's Encrypt cert and redirects HTTP → HTTPS.
# SITE_ADDRESS=cafu.example.com
# CADDY_EMAIL=admin@cafu.example.com
